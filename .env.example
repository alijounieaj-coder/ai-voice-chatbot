# ── Google Gemini ────────────────────────────────────────────────
# Get FREE key from: https://aistudio.google.com/app/apikey
# Free tier: 1,500 requests/day, 15 requests/minute
GOOGLE_API_KEY=...

# ── Fish Audio ───────────────────────────────────────────────────
# Get from: https://fish.audio/app/api-keys
# Free tier: voice cloning included, ~7 min/month TTS
FISH_AUDIO_API_KEY=...

# Your cloned Voice ID — just the ID, NOT the full URL
# Example: 6ec4938305d549788b5314aff68d50af
# Get from: fish.audio → My Voices → click voice → copy ID from URL (?modelId=THIS_PART)
FISH_AUDIO_VOICE_ID=...

# (Optional) Separate Voice ID for Arabic responses
# Leave empty to use the same voice for both languages
FISH_AUDIO_VOICE_ID_AR=
