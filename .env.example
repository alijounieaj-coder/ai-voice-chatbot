# ── Groq (LLM — free) ────────────────────────────────────────────
# Get FREE key: https://console.groq.com
GROQ_API_KEY=...

# ── Fish Audio (TTS — your cloned voice) ─────────────────────────
# Get key: https://fish.audio/app/api-keys
FISH_AUDIO_API_KEY=...

# English voice ID (from fish.audio → My Voices → copy ID from URL)
FISH_AUDIO_VOICE_ID=...

# Arabic voice ID (can be same as above if one voice covers both)
FISH_AUDIO_VOICE_ID_AR=...
